# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers
GROQ_API_KEY=
MISTRAL_API_KEY=
# Model overrides (optional)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_RESEARCH_MODEL=llama-3.3-70b-versatile

# News providers
MARKETAUX_API_KEY=
NEWSDATA_API_KEY=
# Tavily web search (fallback after Google News RSS)
TAVILY_API_KEY=

# Auth (Twilio phone OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# Email (Nodemailer SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cron auth
CRON_SECRET=

# Agent tuning (optional)
AGENT_STOCK_TEMP=0.6
AGENT_STOCK_MAX_TOKENS=8192
AGENT_STOCK_STREAM=true
AGENT_STOCK_TIMEOUT_MS=120000
AGENT_GENERAL_TEMP=0.6
AGENT_GENERAL_MAX_TOKENS=2048
AGENT_GENERAL_BRIEF_TEMP=0.8
AGENT_GENERAL_BRIEF_MAX_TOKENS=140
AGENT_GENERAL_STREAM=true
AGENT_GENERAL_TIMEOUT_MS=120000
AGENT_BRIEF_TEMP=0.6
AGENT_BRIEF_MAX_TOKENS=3000
AGENT_BRIEF_TIMEOUT_MS=90000
AGENT_RESEARCH_TEMP=0.4
AGENT_RESEARCH_MAX_TOKENS=8192
